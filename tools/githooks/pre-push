#!/bin/sh
# Final safety net: block pushes if the vault check fails.
# Installed via: git config core.hooksPath tools/githooks
cd "$(git rev-parse --show-toplevel)" || exit 1

if ! command -v uv >/dev/null 2>&1; then
    echo "pre-push: 'uv' not found; cannot run vault check. Push blocked (fail-closed)." >&2
    exit 1
fi

if ! uv run vault check; then
    echo "" >&2
    echo "pre-push: vault check FAILED - push blocked. See message above." >&2
    exit 1
fi
